<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    tools:context=".fragments.sports.soccer.SoccerControlBarFragment">

    <LinearLayout
        android:id="@+id/control_home"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/alpha_background"
        android:orientation="horizontal"
        android:padding="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent">

        <!-- Colonna sinistra: minus, score e TeamControlView -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="3dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/home_score_minus"
                    android:src="@drawable/minus_one"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center_vertical"
                    tools:ignore="ContentDescription"/>

                <TextView
                    android:id="@+id/home_score"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="5dp"
                    android:gravity="center"
                    android:minWidth="40dp"
                    android:textColor="@color/primary"
                    android:text= "@string/score_placeholder"/>
            </LinearLayout>

            <it.lmqv.livematchcam.views.TeamControlView
                android:id="@+id/homeTeamControl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                app:textColor="@color/primary" />
        </LinearLayout>

        <!-- Colonna destra: bottoni +1, +2, +3 allineati verticalmente -->
        <LinearLayout
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:layout_margin="3dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/home_score_add"
                android:src="@drawable/add_one"
                android:layout_width="50dp"
                android:layout_height="50dp"
                tools:ignore="ContentDescription"/>

            <ImageView
                android:id="@+id/home_score_add_two"
                android:src="@drawable/add_two"
                android:layout_width="50dp"
                android:layout_height="50dp"
                tools:ignore="ContentDescription"/>

            <ImageView
                android:id="@+id/home_score_add_three"
                android:src="@drawable/add_three"
                android:layout_width="50dp"
                android:layout_height="50dp"
                tools:ignore="ContentDescription"/>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/controls_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/TRANSPARENT"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="4dp"

        app:layout_constraintEnd_toStartOf="@+id/control_away"
        app:layout_constraintStart_toEndOf="@+id/control_home"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/change_period"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/alpha_background"
            android:src="@drawable/change_period"
            tools:ignore="ContentDescription" />

        <FrameLayout
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:layout_marginHorizontal="10dp">

            <ImageView
                android:id="@+id/stop_time"
                android:layout_width="75dp"
                android:layout_height="75dp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/time_pause"
                android:visibility="gone"
                tools:ignore="ContentDescription" />

            <ImageView
                android:id="@+id/start_time"
                android:layout_width="75dp"
                android:layout_height="75dp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/time_start"
                tools:ignore="ContentDescription" />
        </FrameLayout>

        <!--ImageView
            android:id="@+id/reset_time"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/alpha_background"
            android:src="@drawable/time_reset"
            app:tint="@color/image_tint_secondary_selector"
            tools:ignore="ContentDescription" /-->

        <TextView
            android:id="@+id/match_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/alpha_background"
            android:gravity="center"
            android:padding="4dp"
            android:text="@string/time_placeholder"
            android:textColor="@color/primary"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/control_away"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/alpha_background"
        android:orientation="horizontal"
        android:padding="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <!-- Colonna sinistra: minus, score e TeamControlView -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="3dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/away_score_minus"
                    android:src="@drawable/minus_one"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center_vertical"
                    tools:ignore="ContentDescription"/>

                <TextView
                    android:id="@+id/away_score"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="5dp"
                    android:gravity="center"
                    android:minWidth="40dp"
                    android:textColor="@color/primary"
                    android:text= "@string/score_placeholder"/>
            </LinearLayout>

            <it.lmqv.livematchcam.views.TeamControlView
                android:id="@+id/guestTeamControl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:paddingTop="4dp"
                app:textColor="@color/primary" />
        </LinearLayout>

        <!-- Colonna destra: bottoni +1, +2, +3 allineati verticalmente -->
        <LinearLayout
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:layout_margin="3dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/away_score_add"
                android:src="@drawable/add_one"
                android:layout_width="50dp"
                android:layout_height="50dp"
                tools:ignore="ContentDescription"/>

            <ImageView
                android:id="@+id/away_score_add_two"
                android:src="@drawable/add_two"
                android:layout_width="50dp"
                android:layout_height="50dp"
                tools:ignore="ContentDescription"/>

            <ImageView
                android:id="@+id/away_score_add_three"
                android:src="@drawable/add_three"
                android:layout_width="50dp"
                android:layout_height="50dp"
                tools:ignore="ContentDescription"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>