<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    tools:context=".fragments.soccer.SoccerControlBarFragment">

    <LinearLayout
        android:id="@+id/control_home"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/alpha_background"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4">

            <ImageView
                android:id="@+id/home_color"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:gravity="start"
                android:src="@drawable/shirt_layers" />

            <TextView
                android:id="@+id/home_team"
                android:layout_width="0dp"
                android:layout_weight="3"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/primary"
                android:text="@string/home_team"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/home_score_minus"
                android:src="@drawable/minus"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                tools:ignore="ContentDescription"/>

            <TextView
                android:id="@+id/home_score"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="5dp"
                android:gravity="center"
                android:textSize="20sp"
                android:minWidth="40dp"
                android:textColor="@color/primary"
                android:text= "@string/score_placeholder"/>

            <ImageView
                android:id="@+id/home_score_add"
                android:src="@drawable/add"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                tools:ignore="ContentDescription"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/controls_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/TRANSPARENT"
        android:gravity="center"
        android:padding="4dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="0dp">

        <ImageView
            android:id="@+id/change_period"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/alpha_background"
            android:src="@drawable/change_period"
            tools:ignore="ContentDescription" />

        <FrameLayout
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:layout_marginHorizontal="50dp">
            <ImageView
                android:id="@+id/stop_time"
                android:visibility="gone"
                android:layout_width="75dp"
                android:layout_height="75dp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/time_pause"
                tools:ignore="ContentDescription" />
            <ImageView
                android:id="@+id/start_time"
                android:layout_width="75dp"
                android:layout_height="75dp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/time_start"
                tools:ignore="ContentDescription" />
        </FrameLayout>

        <ImageView
            android:id="@+id/reset_time"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/alpha_background"
            android:src="@drawable/time_reset"
            app:tint="@color/image_tint_secondary_selector"
            tools:ignore="ContentDescription" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/control_away"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/alpha_background"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4">

            <TextView
                android:id="@+id/away_team"
                android:layout_width="0dp"
                android:layout_weight="3"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/primary"
                android:text="@string/away_team"/>

            <ImageView
                android:id="@+id/away_color"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:gravity="start"
                android:src="@drawable/shirt_layers" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/away_score_minus"
                android:src="@drawable/minus"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                tools:ignore="ContentDescription"/>

            <TextView
                android:id="@+id/away_score"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="5dp"
                android:gravity="center"
                android:textSize="20sp"
                android:minWidth="40dp"
                android:textColor="@color/primary"
                android:text= "@string/score_placeholder"/>

            <ImageView
                android:id="@+id/away_score_add"
                android:src="@drawable/add"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                tools:ignore="ContentDescription"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>