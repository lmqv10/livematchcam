<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="100dp"
    android:background="@drawable/alpha_background"
    android:orientation="vertical"
    tools:context=".fragments.status.UVCStatusFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="3dp"
        android:background="@drawable/secondary_background"
        android:weightSum="4">

        <ImageView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:layout_gravity="center_vertical"
            android:contentDescription="@string/description_placeholder"
            android:src="@drawable/ic_cloud_upload" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:weightSum="3">

            <TextView
                android:id="@+id/bitrate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:padding="3dp"
                android:gravity="end"
                android:layout_gravity="center_vertical"
                android:textSize="11sp"
                android:text="@string/bitrate_placeholder" />

            <TextView
                android:id="@+id/fps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:padding="3dp"
                android:gravity="end"
                android:layout_gravity="center_vertical"
                android:textSize="11sp"
                android:text="@string/fps_placeholder" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/alpha_background"
        android:layout_margin="3dp"
        android:weightSum="4">

        <ImageView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:padding="3dp"
            android:layout_gravity="center_vertical"
            android:contentDescription="@string/description_placeholder"
            android:src="@drawable/ic_handycam" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:weightSum="3">

            <TextView
                android:id="@+id/sourceResolution"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:padding="3dp"
                android:gravity="center_horizontal"
                android:background="@drawable/alpha_background"
                android:layout_gravity="center_vertical"
                android:textSize="11sp"
                android:text="@string/resolution_placeholder" />

            <TextView
                android:id="@+id/sourceFps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:textColor="@color/primary"
                android:padding="3dp"
                android:gravity="center_horizontal"
                android:background="@drawable/alpha_background"
                android:layout_gravity="center_vertical"
                android:textSize="11sp"
                android:text="@string/fps_placeholder" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
