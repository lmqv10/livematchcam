<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <it.lmqv.livematchcam.views.SwipeSurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="0dp" />

    <FrameLayout
        android:id="@+id/status_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />

    <TextView
        android:id="@+id/streaming_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:gravity="center"
        android:textColor="@color/primary"
        android:text="@string/streamin_time"
        app:layout_constraintTop_toTopOf="parent"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/control_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/TRANSPARENT"
        app:layout_constraintTop_toBottomOf="@+id/streaming_time">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_audio_monitor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.22" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_microphone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.33" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.605" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.4" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_usb_audio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.73" />

        <ImageView
            android:id="@+id/audio_monitor_toggle"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/alpha_background"
            android:src="@drawable/ic_headphones_off"
            app:layout_constraintStart_toStartOf="@id/guideline_audio_monitor"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/microphone"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/alpha_background"
            android:src="@drawable/microphone_on"
            app:layout_constraintStart_toStartOf="@id/guideline_microphone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/b_start_stop"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:background="@drawable/alpha_background"
            android:src="@drawable/stream_icon"
            android:clickable="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/change_resolution_strategy"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/alpha_background"
            android:src="@drawable/ic_settings"
            android:clickable="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/guideline_settings"
            android:layout_marginEnd="8dp"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/usb_audio_source"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/alpha_background"
            android:src="@drawable/ic_usb_audio"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/guideline_usb_audio"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:visibility="gone"
            android:id="@+id/go_live_container"
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/guideline_source">

            <TextView
                android:id="@+id/go_live_tip"
                android:text="@string/go_live"
                android:textColor="@color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/go_live_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/replay_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:clickable="false"
        android:background="@color/TRANSPARENT"
        app:layout_constraintTop_toBottomOf="@+id/control_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:clickable="false"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/b_replay"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/alpha_background"
                android:clickable="false"
                android:visibility="gone"
                android:padding="8dp"
                android:src="@drawable/ic_replay"
                tools:ignore="ContentDescription" />

            <ImageView
                android:id="@+id/b_quick_replay"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="20dp"
                android:background="@drawable/alpha_background"
                android:clickable="false"
                android:visibility="gone"
                android:padding="8dp"
                android:src="@drawable/ic_quick_replay"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/b_replay"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="ContentDescription" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="top"
        android:layout_gravity="top"
        android:layout_marginStart="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/streaming_time"
        app:layout_constraintBottom_toTopOf="@+id/control_bar_container">

<!--        <ImageView-->
<!--            android:id="@+id/change_filters_strategy"-->
<!--            android:layout_width="50dp"-->
<!--            android:layout_height="50dp"-->
<!--            android:gravity="top|center_horizontal"-->
<!--            android:layout_gravity="center_horizontal"-->
<!--            android:src="@drawable/ic_resize"-->
<!--            android:clickable="false"-->
<!--            tools:ignore="ContentDescription" />-->

        <FrameLayout
            android:id="@+id/banners_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/control_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="5dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- REPLAY OVERLAYS -->
    <!-- Seeking Overlay -->
    <FrameLayout
        android:id="@+id/replay_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        tools:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>