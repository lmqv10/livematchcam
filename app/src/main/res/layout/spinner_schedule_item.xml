<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/schedule_item_min_height"
    android:orientation="vertical"
    android:background="@drawable/alpha_background"
    android:layout_margin="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/iv_home_logo"
            android:layout_width="@dimen/image_size_width_smaller"
            android:layout_height="@dimen/image_size_width_smaller"
            android:padding="5dp"
            android:src="@drawable/shield_add"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/tv_home_team_name"
            style="@style/TeamTextViewStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:gravity="center_vertical|center"
            android:maxLines="1"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="1"
            android:scrollHorizontally="true"
            android:focusable="false"
            android:text="@string/hint_home_team"/>

        <TextView
            android:id="@+id/tv_away_team_name"
            style="@style/TeamTextViewStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:gravity="center_vertical|center"
            android:maxLines="1"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="1"
            android:scrollHorizontally="true"
            android:focusable="false"
            android:text="@string/hint_away_team"/>

        <ImageView
            android:id="@+id/iv_away_logo"
            android:layout_width="@dimen/image_size_width_smaller"
            android:layout_height="@dimen/image_size_width_smaller"
            android:padding="5dp"
            android:src="@drawable/shield_add"
            tools:ignore="ContentDescription" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_match_info"
        android:textSize="@dimen/text_size_small"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:maxLines="1"
        android:singleLine="true"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="1"
        android:scrollHorizontally="true"
        android:focusable="false"
        android:text="@string/hint_match_date"/>
</LinearLayout>
