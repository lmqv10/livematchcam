<!--                android:textColor="@color/black"-->
<!--                android:text="@string/home_team"/>-->
<!--        </LinearLayout>-->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/home_score_minus"
                android:src="@drawable/minus"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                android:contentDescription="@string/description_placeholder" />

            <TextView
                android:id="@+id/home_score"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="5dp"
                android:gravity="center"
                android:textSize="20sp"
                android:minWidth="40dp"
                android:textColor="@color/black"
                android:text= "@string/score_placeholder"/>

            <ImageView
                android:id="@+id/home_score_add"
                android:src="@drawable/add"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                android:contentDescription="@string/description_placeholder" />
        </LinearLayout>

        <it.lmqv.livematchcam.views.TeamControlView
            android:layout_marginTop="5dp"
            android:id="@+id/homeTeamControl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/controls_match"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintEnd_toStartOf="@+id/control_away"
        app:layout_constraintStart_toEndOf="@+id/control_home"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="5dp"
            android:background="@drawable/alpha_background">

            <ImageView
                android:id="@+id/remove_last_set"
                android:src="@drawable/minus"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                tools:ignore="ContentDescription"/>

            <TextView
                android:id="@+id/current_set"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="5dp"
                android:gravity="center"
                android:textSize="20sp"
                android:minWidth="40dp"
                android:textColor="@color/black"
                android:text= "@string/first_set_placeholder"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:paddingHorizontal="5dp"
                android:gravity="center"
                android:textSize="20sp"
                android:minWidth="40dp"
                android:textColor="@color/black"
                android:text= "@string/set_placeholder"/>
            <ImageView
                android:id="@+id/add_new_set"
                android:src="@drawable/add"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                tools:ignore="ContentDescription"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/match_league"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                android:layout_marginBottom="5dp"
                android:src="@drawable/edit_pen"
                tools:ignore="ContentDescription" />

            <ImageView
                android:id="@+id/reset_match"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/reset_match"
                tools:ignore="ContentDescription" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/control_away"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/alpha_background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent">

<!--        <LinearLayout-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="30dp"-->
<!--            android:orientation="horizontal"-->
<!--            android:layout_marginBottom="5dp"-->
<!--            android:weightSum="4">-->

<!--            <TextView-->
<!--                android:id="@+id/away_team"-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_weight="3"-->
<!--                android:layout_height="match_parent"-->
<!--                android:gravity="center"-->
<!--                android:textColor="@color/black"-->
<!--                android:text="@string/away_team"/>-->

<!--            <ImageView-->
<!--                android:id="@+id/guest_color"-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_weight="1"-->
<!--                android:layout_height="match_parent"-->
<!--                android:gravity="start"-->
<!--                android:src="@drawable/shirt_layers"-->
<!--                android:contentDescription="@string/description_placeholder" />-->
<!--        </LinearLayout>-->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/away_score_minus"
                android:src="@drawable/minus"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                tools:ignore="ContentDescription"/>

            <TextView
                android:id="@+id/away_score"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="5dp"
                android:gravity="center"
                android:textSize="20sp"
                android:minWidth="40dp"
                android:textColor="@color/black"
                android:text= "@string/score_placeholder"/>

            <ImageView
                android:id="@+id/away_score_add"
                android:src="@drawable/add"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                tools:ignore="ContentDescription"/>
        </LinearLayout>

        <it.lmqv.livematchcam.views.TeamControlView
            android:layout_marginTop="5dp"
            android:id="@+id/guestTeamControl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/spot_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/alpha_background"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/control_home">

        <ImageView
            android:id="@+id/spot_banner_preview"
            android:layout_width="100dp"
            android:layout_height="50dp"
            android:src="@drawable/preview_missing"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/spot_banner_trash"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="10dp"
            android:src="@drawable/ic_trash_bin"
            tools:ignore="ContentDescription" />

        <Switch
            android:id="@+id/spot_banner_switch"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="5dp"
            android:text="@string/spot_banner"
            tools:ignore="UseSwitchCompatOrMaterialXml" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/main_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="5dp"
        android:background="@drawable/alpha_background"
        app:layout_constraintTop_toBottomOf="@+id/spot_banner"
        app:layout_constraintLeft_toLeftOf="parent">

        <ImageView
            android:id="@+id/main_banner_preview"
            android:src="@drawable/preview_missing"
            android:layout_width="100dp"
            android:layout_height="50dp"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/main_banner_trash"
            android:src="@drawable/ic_trash_bin"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="10dp"
            android:layout_width="30dp"
            android:layout_height="30dp"
            tools:ignore="ContentDescription" />

        <Switch
                android:id="@+id/main_banner_switch"
                android:text="@string/main_banner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="5dp"
                android:gravity="center"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>