<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_camera"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

  <it.lmqv.livematchcam.SwipeSurfaceView
      android:id="@+id/surfaceView"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      tools:layout_editor_absoluteX="0dp"
      tools:layout_editor_absoluteY="0dp" />

  <FrameLayout
      android:visibility="invisible"
      android:id="@+id/score_board_placeholder"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintStart_toStartOf="@id/surfaceView"
      app:layout_constraintTop_toTopOf="@id/surfaceView"/>

  <LinearLayout
      android:id="@+id/control_audio"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@color/TRANSPARENT"
      android:gravity="center"
      android:padding="4dp"
      android:orientation="horizontal"
      app:layout_constraintTop_toTopOf="parent"
      tools:layout_editor_absoluteX="0dp">

    <ImageView
        android:id="@+id/change_period"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="center_vertical"
        android:background="@drawable/alpha_background"
        android:src="@drawable/change_period"
        android:layout_marginRight="60dp"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/reset_time"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="center_vertical"
        android:background="@drawable/alpha_background"
        android:src="@drawable/time_reset"
        app:tint="@color/image_tint_secondary_selector"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/start_time"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:layout_gravity="center_vertical"
        android:background="@drawable/alpha_background"
        android:layout_marginLeft="5dp"
        android:layout_marginRight="60dp"
        android:src="@drawable/time_start"
        tools:ignore="ContentDescription" />


    <ImageView
        android:id="@+id/microphone"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center_vertical"
        android:background="@drawable/alpha_background"
        android:src="@drawable/microphone_on"
        tools:ignore="ContentDescription" />
  </LinearLayout>


  <FrameLayout
      android:id="@+id/status_container"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="5dp"
      android:layout_marginEnd="70dp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      />

  <LinearLayout
      android:visibility="gone"
      android:id="@+id/control_top"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:background="@drawable/alpha_background"
      android:orientation="vertical"
      android:layout_marginTop="5dp"
      android:layout_marginEnd="70dp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintTop_toTopOf="parent" >

    <!--ImageView
        android:id="@+id/iv_exit"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="center_vertical"
        android:src="@drawable/zoom_offset"
        tools:ignore="ContentDescription" /-->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:minHeight="40dp"
        android:weightSum="2">
      <TextView
          android:id="@+id/txt_bitrate"
          android:layout_width="0dp"
          android:layout_weight="1"
          android:layout_height="wrap_content"
          android:textColor="@color/primary"
          android:textStyle="bold"
          android:padding="5dp"
          android:gravity="center"
          android:layout_gravity="center_vertical"
          android:textSize="10sp"
          android:text="@string/bitrate_placeholder" />

      <Switch
          android:id="@+id/switch_zoom"
          android:layout_width="0dp"
          android:layout_weight="1"
          android:layout_height="match_parent"
          android:minHeight="49dp"
          android:layout_gravity="center_horizontal" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

      <TextView
          android:id="@+id/left_degree"
          android:layout_width="0dp"
          android:layout_weight="1"
          android:layout_height="wrap_content"
          android:gravity="center"
          android:layout_gravity="center"
          android:paddingLeft="4dp"
          android:paddingVertical="2dp"
          android:textSize="12sp"
          android:minWidth="40dp"
          android:textColor="@color/YELLOW"
          android:textStyle="bold"
          android:text="@string/degree_placeholder" />
      <TextView
          android:id="@+id/right_degree"
          android:layout_width="0dp"
          android:layout_weight="1"
          android:layout_height="wrap_content"
          android:gravity="center"
          android:layout_gravity="center"
          android:paddingLeft="4dp"
          android:paddingVertical="2dp"
          android:textSize="12sp"
          android:minWidth="40dp"
          android:textColor="@color/YELLOW"
          android:textStyle="bold"
          android:text="@string/degree_placeholder" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
      <TextView
          android:id="@+id/x_degree"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:gravity="center"
          android:layout_gravity="center"
          android:paddingLeft="4dp"
          android:paddingVertical="2dp"
          android:textSize="12sp"
          android:minWidth="40dp"
          android:textColor="@color/primary"
          android:textStyle="bold"
          android:text="@string/degree_placeholder" />

      <TextView
          android:id="@+id/zoom_level"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:gravity="center"
          android:layout_gravity="center"
          android:padding="3dp"
          android:textSize="12sp"
          android:minWidth="30dp"
          android:textColor="@color/primary"
          android:textStyle="bold"
          android:text="@string/zoom_placeholder" />

      <TextView
          android:id="@+id/initial_zoom"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:gravity="center"
          android:layout_gravity="center"
          android:padding="3dp"
          android:textSize="12sp"
          android:minWidth="30dp"
          android:textColor="@color/primary"
          android:textStyle="bold"
          android:text="@string/zoom_placeholder" />

    </LinearLayout>

  <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal">
    <ImageView
        android:id="@+id/reset_rotation"
        android:src="@drawable/switch_icon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="center"
        tools:ignore="ContentDescription"/>

    <ImageView
        android:id="@+id/zoom_offset"
        android:src="@drawable/zoom_offset"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:padding="8dp"
        android:layout_gravity="center"
        tools:ignore="ContentDescription"/>
  </LinearLayout>
  </LinearLayout>

  <LinearLayout
      android:id="@+id/control_bar"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@color/TRANSPARENT"
      android:orientation="horizontal"
      android:gravity="center"
      app:layout_constraintBottom_toTopOf="@+id/streaming_time">

    <ImageView
        android:id="@+id/b_start_stop"
        android:src="@drawable/stream_icon"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:background="@drawable/alpha_background"
        android:clickable="false"
        tools:ignore="ContentDescription"/>

  </LinearLayout>

  <TextView
      android:id="@+id/streaming_time"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="right"
      android:textStyle="bold"
      android:gravity="center"
      android:textColor="@color/primary"
      android:text="@string/streamin_time"
      app:layout_constraintBottom_toBottomOf="parent"/>

  <LinearLayout
      android:id="@+id/control_home"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:background="@drawable/alpha_background"
      android:orientation="vertical"
      android:layout_marginStart="70dp"
      android:layout_marginBottom="5dp"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintLeft_toLeftOf="parent">

  <TextView
      android:id="@+id/home_team"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center"
      android:textStyle="bold"
      android:textColor="@color/primary"
      android:text="@string/home_team"/>

  <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal">

    <ImageView
        android:src="@drawable/minus"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:id="@+id/home_score_minus"
        android:layout_gravity="center_vertical"
        tools:ignore="ContentDescription"/>

    <TextView
        android:id="@+id/home_score"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="5dp"
        android:gravity="center"
        android:textStyle="bold"
        android:textSize="20sp"
        android:minWidth="40dp"
        android:textColor="@color/primary"
        android:text= "@string/score_placeholder"/>

    <ImageView
        android:src="@drawable/add"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:id="@+id/home_score_add"
        android:layout_gravity="center_vertical"
        tools:ignore="ContentDescription"/>
    </LinearLayout>
  </LinearLayout>

  <LinearLayout
      android:id="@+id/control_away"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:background="@drawable/alpha_background"
      android:orientation="vertical"
      android:layout_marginEnd="70dp"
      android:layout_marginBottom="5dp"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintRight_toRightOf="parent">

    <TextView
        android:id="@+id/away_team"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:text="@string/away_team"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
      <ImageView
          android:src="@drawable/minus"
          android:layout_width="50dp"
          android:layout_height="50dp"
          android:id="@+id/away_score_minus"
          android:layout_gravity="center_vertical"
          tools:ignore="ContentDescription"/>

      <TextView
          android:id="@+id/away_score"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:paddingHorizontal="5dp"
          android:gravity="center"
          android:textStyle="bold"
          android:textSize="20sp"
          android:minWidth="40dp"
          android:textColor="@color/primary"
          android:text= "@string/score_placeholder"/>

      <ImageView
          android:src="@drawable/add"
          android:layout_width="50dp"
          android:layout_height="50dp"
          android:id="@+id/away_score_add"
          android:layout_gravity="center_vertical"
          tools:ignore="ContentDescription"/>
    </LinearLayout>

  </LinearLayout>

  <!--androidx.constraintlayout.widget.ConstraintLayout
      android:id="@+id/record_tools"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:layout_constraintBottom_toTopOf="@id/control_bar"
      android:layout_margin="16dp"
      >
    <ImageView
        android:src="@drawable/record_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:id="@+id/b_record"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/b_start_stop"
        app:layout_constraintHorizontal_chainStyle="spread"
        />

    <ImageView
        android:src="@drawable/stream_icon"
        android:layout_width="98dp"
        android:layout_height="98dp"
        android:id="@+id/b_start_stop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/b_record"
        app:layout_constraintEnd_toStartOf="@id/switch_camera"
        />

    <ImageView
        android:src="@drawable/switch_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:id="@+id/switch_camera"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/b_start_stop"
        />
  </androidx.constraintlayout.widget.ConstraintLayout-->

</androidx.constraintlayout.widget.ConstraintLayout>
