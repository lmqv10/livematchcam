<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include
        android:id="@+id/toolbar"
        layout="@layout/custom_toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:layout_marginTop="?attr/actionBarSize"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:weightSum="2">

        <FrameLayout
            android:id="@+id/serversContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            />

        <FrameLayout
            android:id="@+id/sportsContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            />
    </LinearLayout>

    <!--Button
        android:visibility="gone"
        android:id="@+id/activity_youtube"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/score_board_secondary_background"
        android:paddingHorizontal="40dp"
        android:paddingVertical="5dp"
        android:text="TEST"
        android:textColor="@color/primary"
        android:textStyle="bold"
        android:layout_marginStart="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_version"
        app:layout_constraintStart_toStartOf="parent" /-->

    <ImageView
        android:id="@+id/activity_Live"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/score_board_secondary_background"
        android:contentDescription="@string/live_stream"
        android:paddingHorizontal="40dp"
        android:paddingVertical="5dp"
        android:src="@drawable/play_stream"
        app:tint="@color/white"
        android:textStyle="bold"
        android:layout_marginEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_version"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/activity_usb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/score_board_secondary_background"
        android:paddingHorizontal="40dp"
        android:paddingVertical="5dp"
        android:src="@drawable/usb_cam"
        app:tint="@color/white"
        android:textStyle="bold"
        android:layout_marginEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_version"
        app:layout_constraintEnd_toStartOf="@id/activity_Live" />
    <TextView
        android:id="@+id/tv_version"
        android:layout_width="match_parent"
        android:gravity="left"
        android:textColor="@color/secondary_dark"
        android:textSize="10sp"
        android:textStyle="bold"
        android:text="@string/version"
        android:paddingHorizontal="5dp"
        android:paddingBottom="2dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
