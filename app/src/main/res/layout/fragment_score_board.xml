<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/score_board_primary_background"
        android:padding="4dp"
        android:minWidth="120dp"
        android:layout_margin="5dp">

        <TextView
            android:visibility="gone"
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:textColor="@color/BLACK"
            android:text="@string/description_placeholder"
            android:textStyle="bold"
            android:padding="3dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="3dp"
            android:paddingHorizontal="2dp"
            android:weightSum="8">

            <ImageView
                android:id="@+id/home_logo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:src="@drawable/shirt_stroke"
                android:gravity="start" />

            <TextView
                android:id="@+id/home_team"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="4"
                android:textColor="@color/BLACK"
                android:textStyle="bold"
                android:paddingStart="2dp"
                android:text="@string/hint_home_team"
                android:gravity="center" />

            <TextView
                android:id="@+id/home_score"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@drawable/score_board_primary_background"
                android:text="@string/score_placeholder" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="3dp"
            android:paddingHorizontal="2dp"
            android:weightSum="8">

            <ImageView
                android:id="@+id/away_logo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:src="@drawable/shirt"
                android:gravity="start"/>

            <TextView
                android:id="@+id/away_team"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="4"
                android:textColor="@color/BLACK"
                android:text="@string/hint_away_team"
                android:textStyle="bold"
                android:paddingStart="2dp"
                android:gravity="center" />

            <TextView
                android:id="@+id/away_score"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@drawable/score_board_primary_background"
                android:text="@string/score_placeholder"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/score_board_secondary_background"
            android:padding="2dp"
            android:weightSum="4">

            <TextView
                android:id="@+id/match_period"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/period_placeholder"
                android:layout_weight="3"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center" />

            <TextView
                android:id="@+id/match_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@drawable/score_board_primary_background"
                android:textAlignment="textEnd"
                android:paddingEnd="5dp"
                android:text="@string/time_placeholder"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>