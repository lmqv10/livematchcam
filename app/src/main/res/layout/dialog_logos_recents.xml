<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dialogRoot"
    android:layout_width="@dimen/dialog_width"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/score_board_primary_background"
    android:padding="24dp">

    <TextView
        android:id="@+id/logo_url_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:textColor="@color/secondary_darker"
        android:text="@string/choose_logo"/>

    <EditText
        android:id="@+id/editTextInput"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="@string/logo_url_placeholder"
        android:autofillHints="url"
        android:inputType="textUri"
        android:imeOptions="actionDone"
        tools:ignore="TextFields" />

    <GridView
        android:numColumns="5"
        android:id="@+id/recentsList"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:columnWidth="50dp"
        android:layout_marginTop="8dp"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="4dp"
        android:layout_marginTop="10dp">

        <ImageView
            style="@style/DefaultImageViewStyle"
            android:id="@+id/clearButton"
            android:src="@drawable/ic_eraser"
            android:contentDescription="@string/description_placeholder"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <ImageView
            android:visibility="gone"
            style="@style/DefaultImageViewStyle"
            android:id="@+id/cancelButton"
            android:src="@drawable/ic_cancel"
            android:layout_gravity="start"
            android:contentDescription="@string/description_placeholder"
            android:layout_marginEnd="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/confirmButton"/>

        <ImageView
            style="@style/DefaultImageViewStyle"
            android:id="@+id/confirmButton"
            android:src="@drawable/ic_confirm"
            android:contentDescription="@string/description_placeholder"
            android:layout_marginEnd="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
