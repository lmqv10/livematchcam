<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_vertical"
    tools:context=".fragments.sports.volley.VolleyControlBarFragment">

    <LinearLayout
        android:id="@+id/control_home"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/alpha_background"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent">

<!--        <LinearLayout-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="30dp"-->
<!--            android:orientation="horizontal"-->
<!--            android:layout_marginBottom="5dp"-->
<!--            android:weightSum="4">-->

<!--            <ImageView-->
<!--                android:id="@+id/home_color"-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_weight="1"-->
<!--                android:layout_height="match_parent"-->
<!--                android:gravity="start"-->
<!--                android:src="@drawable/shirt_layers" />-->

<!--            <TextView-->
<!--                android:id="@+id/home_team"-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_weight="3"-->
<!--                android:layout_height="match_parent"-->
<!--                android:gravity="center"-->
<!--                android:textColor="@color/primary"-->
<!--                android:text="@string/home_team"/>-->
<!--        </LinearLayout>-->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/home_score_minus"
                android:src="@drawable/minus"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                tools:ignore="ContentDescription"/>

            <TextView
                android:id="@+id/home_score"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="5dp"
                android:gravity="center"
                android:textSize="20sp"
                android:minWidth="40dp"
                android:textColor="@color/primary"
                android:text= "@string/score_placeholder"/>

            <ImageView
                android:id="@+id/home_score_add"
                android:src="@drawable/add"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                tools:ignore="ContentDescription"/>
        </LinearLayout>

        <View style="@style/dividerStyle"/>

        <it.lmqv.livematchcam.views.TeamControlView
            android:id="@+id/homeTeamControl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:textColor="@color/primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/controls_match"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_constraintEnd_toStartOf="@+id/control_away"
        app:layout_constraintStart_toEndOf="@+id/control_home"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="5dp"
            android:background="@drawable/alpha_background">

            <ImageView
                android:id="@+id/remove_last_set"
                android:src="@drawable/minus"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                tools:ignore="ContentDescription"/>

            <TextView
                android:id="@+id/current_set"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="5dp"
                android:gravity="center"
                android:textSize="20sp"
                android:minWidth="40dp"
                android:textColor="@color/primary"
                android:text= "@string/first_set_placeholder"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:paddingHorizontal="5dp"
                android:gravity="center"
                android:textSize="20sp"
                android:minWidth="40dp"
                android:textColor="@color/primary"
                android:text= "@string/set_placeholder"/>
            <ImageView
                android:id="@+id/add_new_set"
                android:src="@drawable/add"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                tools:ignore="ContentDescription"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/match_league_description"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                android:background="@drawable/alpha_background"
                android:layout_marginBottom="5dp"
                android:src="@drawable/edit_pen"
                tools:ignore="ContentDescription" />

            <ImageView
                android:id="@+id/reset_match"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                android:background="@drawable/alpha_background"
                android:src="@drawable/reset_match"
                tools:ignore="ContentDescription" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/control_away"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/alpha_background"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent">

<!--        <LinearLayout-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="30dp"-->
<!--            android:orientation="horizontal"-->
<!--            android:layout_marginBottom="5dp"-->
<!--            android:weightSum="4">-->

<!--            <TextView-->
<!--                android:id="@+id/away_team"-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_weight="3"-->
<!--                android:layout_height="match_parent"-->
<!--                android:gravity="center"-->
<!--                android:textColor="@color/primary"-->
<!--                android:text="@string/away_team"/>-->

<!--            <ImageView-->
<!--                android:id="@+id/away_color"-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_weight="1"-->
<!--                android:layout_height="match_parent"-->
<!--                android:gravity="start"-->
<!--                android:src="@drawable/shirt_layers" />-->
<!--        </LinearLayout>-->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/away_score_minus"
                android:src="@drawable/minus"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                tools:ignore="ContentDescription"/>

            <TextView
                android:id="@+id/away_score"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="5dp"
                android:gravity="center"
                android:textSize="20sp"
                android:minWidth="40dp"
                android:textColor="@color/primary"
                android:text= "@string/score_placeholder"/>

            <ImageView
                android:id="@+id/away_score_add"
                android:src="@drawable/add"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                tools:ignore="ContentDescription"/>
        </LinearLayout>

        <View style="@style/dividerStyle"/>

        <it.lmqv.livematchcam.views.TeamControlView
            android:id="@+id/guestTeamControl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:textColor="@color/primary" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>