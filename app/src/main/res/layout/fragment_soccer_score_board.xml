<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <TableLayout
        android:layout_width="200dp"
        android:stretchColumns="*"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical">

        <TableRow
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="3dp"
            android:background="@drawable/score_board_background">

            <ImageView
                android:id="@+id/home_logo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:src="@drawable/shirt_layers"
                android:gravity="start" />

            <TextView
                android:id="@+id/home_team"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:textColor="@color/primary"
                android:text="@string/hint_home_team"
                android:gravity="center" />

            <Space android:layout_weight="1"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/away_team"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:textColor="@color/primary"
                android:text="@string/hint_away_team"
                android:gravity="center" />

            <ImageView
                android:id="@+id/away_logo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:src="@drawable/shirt_layers"
                android:gravity="start"/>
        </TableRow>

    </TableLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginVertical="2dp"
        app:cardCornerRadius="1dp"
        app:cardElevation="5dp">

        <LinearLayout
            android:paddingHorizontal="3dp"
            android:minWidth="50dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/match_period"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/period_placeholder"
                android:textColor="@color/white"
                android:background="@drawable/score_board_background"
                android:textSize="10dp"
                android:layout_marginVertical="1dp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4">

                <TextView
                    android:id="@+id/home_score"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:background="@drawable/score_board_primary_background"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:id="@+id/away_score"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:background="@drawable/score_board_primary_background"
                    android:text="@string/score_placeholder"/>
            </LinearLayout>

            <TextView
                android:id="@+id/match_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/time_placeholder"
                android:textColor="@color/BLACK"
                android:textSize="10sp"
                android:gravity="center" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>