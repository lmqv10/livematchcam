<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dialogRoot"
    android:layout_width="@dimen/dialog_width"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/score_board_primary_background"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:minHeight="@dimen/spinner_item_min_height"
        android:layout_marginBottom="5dp"
        android:weightSum="3">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="@string/video_source"
            android:textColor="@color/appColorSecondary"/>

        <Spinner
            android:id="@+id/video_source"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="match_parent"
            android:spinnerMode="dialog" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:minHeight="@dimen/spinner_item_min_height"
        android:layout_marginBottom="5dp"
        android:weightSum="3">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="@string/video_resolution"
            android:textColor="@color/appColorSecondary"/>

        <Spinner
            android:id="@+id/video_resolutions"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="match_parent"
            android:spinnerMode="dialog" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:minHeight="@dimen/spinner_item_min_height"
        android:layout_marginBottom="5dp"
        android:weightSum="3">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="@string/video_fps"
            android:textColor="@color/appColorSecondary"/>

        <Spinner
            android:id="@+id/encoder_fps"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="match_parent"
            android:spinnerMode="dialog" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:minHeight="@dimen/spinner_item_min_height"
        android:weightSum="3">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="@string/video_bitrate"
            android:textColor="@color/appColorSecondary"/>

        <Spinner
            android:id="@+id/encoder_bitrate"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="match_parent"
            android:spinnerMode="dialog" />

    </LinearLayout>

