<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.appbar.MaterialToolbar
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="?attr/actionBarSize"
    android:background="@drawable/action_bar_gradient"
    android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
    android:popupTheme="@style/ThemeOverlay.AppCompat.Light">

    <ImageView
        android:id="@+id/toolbar_icon"
        style="@style/ToolbarImageViewStyle"
        android:src="@mipmap/ic_launcher_adaptive_fore"
        android:contentDescription="@string/description_placeholder" />

    <TextView
        android:id="@+id/toolbar_title"
        style="@style/ToolbarTitleTextViewStyle"
        android:text="@string/app_name"/>

</com.google.android.material.appbar.MaterialToolbar>
