            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:background="@drawable/alpha_background"
                android:padding="10dp"
                android:layout_weight="60"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="vertical">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/text_label_title"
                        style="@style/labelTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_event_title"
                        android:textColor="@color/appColorSecondary"
                        android:padding="3dp"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:ignore="MissingConstraints" />

                    <TextView
                        android:id="@+id/text_title"
                        style="@style/editTextView"
                        android:gravity="start"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/description_placeholder"
                        android:layout_marginEnd="50dp"
                        app:layout_constraintEnd_toStartOf="@+id/iv_title_clear"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/text_label_title"
                        tools:ignore="MissingConstraints" />

                    <it.lmqv.livematchcam.views.AnimateImageVIew
                        android:id="@+id/iv_title_clear"
                        style="@style/smallImageViewStyle"
                        android:contentDescription="@string/description_placeholder"
                        android:src="@drawable/ic_eraser"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/text_label_title"
                        tools:ignore="MissingConstraints" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!--
                <TextView
                    style="@style/labelTextView"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:text="@string/label_datetime"
                    android:textColor="@color/appColorSecondary"
                    android:padding="3dp"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:ignore="MissingConstraints" />

                <TextView
                    android:id="@+id/text_date"
                    style="@style/editTextView"
                    android:gravity="start"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/date_placeholder"
                    app:layout_constraintEnd_toStartOf="@+id/iv_title_clear"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/text_label_title"
                    tools:ignore="MissingConstraints" />
                -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="5dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/text_label_livestream"
                        style="@style/labelTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/live_stream"
                        android:textColor="@color/appColorSecondary"
                        android:padding="3dp"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:ignore="MissingConstraints" />

                    <Spinner
                        android:id="@+id/spinner_livestream"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/text_label_livestream"
                        android:spinnerMode="dialog" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:layout_marginVertical="5dp"
                    android:layout_marginEnd="10dp"
                    android:orientation="horizontal">

                    <it.lmqv.livematchcam.views.AnimateImageVIew
                        android:id="@+id/iv_delete_live_stream"
                        style="@style/largeImageViewStyle"
                        android:layout_gravity="end"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="@string/description_placeholder"
                        android:src="@drawable/ic_trash_bin"/>

                    <it.lmqv.livematchcam.views.AnimateImageVIew
                        android:id="@+id/iv_create_live_stream"
                        style="@style/largeImageViewStyle"
                        android:layout_gravity="end"
                        android:contentDescription="@string/description_placeholder"
                        android:src="@drawable/ic_save"/>

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>