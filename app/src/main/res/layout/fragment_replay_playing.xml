<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="it.lmqv.livematchcam.fragments.replay.ReplayPlayingFragment">

    <Button
        android:id="@+id/replay_stop_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#E53935"
        android:drawableStart="@drawable/ic_stop_replay"
        android:layout_marginTop="10dp"
        android:drawablePadding="8dp"
        android:text="Stop Replay"
        android:textColor="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/replay_speed_container" />

    <LinearLayout
        android:id="@+id/replay_speed_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-60dp"
        android:background="@drawable/alpha_background"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_speed_025"
                style="@style/Widget.AppCompat.Button.Small"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="0.25x"
                android:textSize="10sp"
                android:padding="0dp"
                android:backgroundTint="@color/primary"/>

            <Button
                android:id="@+id/btn_speed_050"
                style="@style/Widget.AppCompat.Button.Small"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="0.50"
                android:textSize="10sp"
                android:padding="0dp"
                android:backgroundTint="@color/primary"/>

            <Button
                android:id="@+id/btn_speed_075"
                style="@style/Widget.AppCompat.Button.Small"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="0.75"
                android:textSize="10sp"
                android:padding="0dp"
                android:backgroundTint="@color/primary"/>

            <Button
                android:id="@+id/btn_speed_100"
                style="@style/Widget.AppCompat.Button.Small"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="1.0"
                android:textSize="10sp"
                android:padding="0dp"
                android:backgroundTint="@color/primary"/>

            <Button
                android:id="@+id/btn_speed_125"
                style="@style/Widget.AppCompat.Button.Small"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="1.25"
                android:textSize="10sp"
                android:padding="0dp"
                android:backgroundTint="@color/primary"/>

            <Button
                android:id="@+id/btn_speed_150"
                style="@style/Widget.AppCompat.Button.Small"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="1.50"
                android:textSize="10sp"
                android:padding="0dp"
                android:backgroundTint="@color/primary"/>

        </LinearLayout>

        <SeekBar
            android:id="@+id/replay_speed_seekbar"
            android:layout_width="250dp"
            android:layout_height="48dp"
            android:max="100"
            android:progress="50"
            android:progressBackgroundTint="@color/primary"
            android:progressBackgroundTintMode="screen"
            android:thumb="@drawable/custom_seekbar_thumb" />

        <TextView
            style="@style/TitleTextViewStyle"
            android:id="@+id/replay_speed_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="0.5x"
            android:textColor="@color/white"
            android:textSize="12sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
