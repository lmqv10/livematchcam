<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="2dp"
        android:layout_margin="7dp">

        <TableLayout
            android:layout_width="200dp"
            android:stretchColumns="*"
            android:layout_height="wrap_content">
            <TableRow
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:weightSum="3">

                <Space android:layout_weight="1"/>

                <TextView
                    android:id="@+id/match_period"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/period_placeholder"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/score_board_secondary_background"
                    android:textSize="10dp"
                    android:gravity="center" />

                <Space android:layout_weight="1"/>
            </TableRow>
            <TableRow
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="3dp"
                android:background="@drawable/score_board_background">

                <ImageView
                    android:id="@+id/home_logo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="2"
                    android:src="@drawable/shirt_layers"
                    android:gravity="start" />

                <TextView
                    android:id="@+id/home_team"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="3"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:text="@string/hint_home_team"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/home_score"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:textAlignment="center"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:background="@drawable/score_board_primary_background"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:id="@+id/away_score"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:textAlignment="center"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:background="@drawable/score_board_primary_background"
                    android:text="@string/score_placeholder"/>

                <TextView
                    android:id="@+id/away_team"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="3"
                    android:textColor="@color/primary"
                    android:text="@string/hint_away_team"
                    android:textStyle="bold"
                    android:gravity="center" />

                <ImageView
                    android:id="@+id/away_logo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="2"
                    android:src="@drawable/shirt_layers"
                    android:gravity="start"/>
            </TableRow>
            <TableRow
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:weightSum="3">

                <Space android:layout_weight="1"/>

                <TextView
                    android:id="@+id/match_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:textSize="10dp"
                    android:gravity="center"
                    android:text="@string/time_placeholder"/>

                <Space android:layout_weight="1"/>
            </TableRow>

        </TableLayout>

