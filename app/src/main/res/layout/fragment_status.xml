<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.StatusFragment">

    <LinearLayout
        android:id="@+id/control_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/alpha_background"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:minHeight="40dp"
            android:weightSum="2">
            <TextView
                android:id="@+id/bitrate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:padding="3dp"
                android:gravity="right"
                android:layout_gravity="center_vertical"
                android:textSize="10sp"
                android:text="@string/bitrate_placeholder" />

            <Switch
                android:id="@+id/auto_zoom_switch"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:minHeight="49dp"
                android:layout_gravity="center_horizontal" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <TextView
                android:id="@+id/left_degree"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_gravity="center"
                android:paddingLeft="4dp"
                android:paddingVertical="2dp"
                android:textSize="14sp"
                android:minWidth="40dp"
                android:textColor="@color/text_color_secondary_selector"
                android:background="@color/WHITESMOKE"
                android:textStyle="bold"
                android:text="@string/degree_placeholder" />
            <TextView
                android:id="@+id/right_degree"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_gravity="center"
                android:paddingLeft="4dp"
                android:paddingVertical="2dp"
                android:textSize="14sp"
                android:minWidth="40dp"
                android:textColor="@color/text_color_secondary_selector"
                android:background="@color/WHITESMOKE"
                android:textStyle="bold"
                android:text="@string/degree_placeholder" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <it.lmqv.livematchcam.views.ToggleTextView
                android:id="@+id/angle_degree"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_gravity="center"
                android:paddingLeft="4dp"
                android:paddingVertical="2dp"
                android:textSize="12sp"
                android:minWidth="40dp"
                android:textColor="@color/text_color_selector"
                android:hint="@string/degree_placeholder"
                android:textStyle="bold"
                android:text="@string/degree_placeholder" />

            <it.lmqv.livematchcam.views.ToggleTextView
                android:id="@+id/zoom_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_gravity="center"
                android:padding="3dp"
                android:textSize="12sp"
                android:minWidth="30dp"
                android:textColor="@color/text_color_selector"
                android:textStyle="bold"
                android:text="@string/zoom_placeholder" />

            <TextView
                android:id="@+id/initial_zoom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_gravity="center"
                android:padding="3dp"
                android:textSize="12sp"
                android:minWidth="30dp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:text="@string/zoom_placeholder" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/reset_rotation"
                android:src="@drawable/switch_icon"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                app:tint="@color/image_tint_selector"
                tools:ignore="ContentDescription"/>

            <ImageView
                android:id="@+id/zoom_offset"
                android:src="@drawable/zoom_offset"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:padding="8dp"
                android:layout_gravity="center"
                app:tint="@color/image_tint_selector"
                tools:ignore="ContentDescription"/>
        </LinearLayout>
    </LinearLayout>


</FrameLayout>