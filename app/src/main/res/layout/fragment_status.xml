<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:maxWidth="@dimen/status_width"
    android:background="@drawable/alpha_background"
    android:orientation="vertical"
    tools:context=".fragments.status.StatusFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="3dp"
        android:background="@drawable/secondary_background"
        android:weightSum="4">

        <ImageView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:layout_gravity="center_vertical"
            android:contentDescription="@string/description_placeholder"
            android:src="@drawable/ic_cloud_upload" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:weightSum="3">

            <TextView
                android:id="@+id/bitrate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:padding="3dp"
                android:gravity="end"
                android:layout_gravity="center_vertical"
                android:text="@string/bitrate_placeholder" />

            <TextView
                android:id="@+id/fps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:padding="3dp"
                android:gravity="end"
                android:layout_gravity="center_vertical"
                android:text="@string/fps_placeholder" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/alpha_background"
        android:layout_margin="3dp"
        android:weightSum="4">

        <ImageView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:padding="3dp"
            android:layout_gravity="center_vertical"
            android:contentDescription="@string/description_placeholder"
            android:src="@drawable/ic_device_camera" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:weightSum="3">

            <TextView
                android:id="@+id/sourceResolution"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:padding="3dp"
                android:gravity="center_horizontal"
                android:background="@drawable/alpha_background"
                android:layout_gravity="center_vertical"
                android:text="@string/resolution_placeholder" />

            <TextView
                android:id="@+id/sourceFps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:textColor="@color/primary"
                android:padding="3dp"
                android:gravity="center_horizontal"
                android:background="@drawable/alpha_background"
                android:layout_gravity="center_vertical"
                android:text="@string/fps_placeholder" />

            <TextView
                android:id="@+id/sourceBitrate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:textColor="@color/primary"
                android:padding="3dp"
                android:gravity="center_horizontal"
                android:background="@drawable/alpha_background"
                android:layout_gravity="center_vertical"
                android:text="@string/bitrate_placeholder" />
        </LinearLayout>
    </LinearLayout>

    <Switch
        android:visibility="gone"
        android:id="@+id/auto_zoom_switch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal" />

    <LinearLayout
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="10">

        <TextView
            android:id="@+id/left_degree"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_gravity="center"
            android:paddingStart="4dp"
            android:paddingEnd="0dp"

            android:paddingVertical="2dp"
            android:minWidth="40dp"
            android:textColor="@color/text_color_secondary_selector"
            android:background="@color/WHITESMOKE"
            android:text="@string/degree_placeholder" />

        <ImageView
            android:id="@+id/arrow_left_degree"
            android:src="@drawable/arrow_left"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            app:tint="@color/secondary"
            android:background="@color/WHITESMOKE"
            tools:ignore="ContentDescription"/>

        <ImageView
            android:id="@+id/arrow_right_degree"
            android:src="@drawable/arrow_right"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            app:tint="@color/secondary"
            android:background="@color/WHITESMOKE"
            tools:ignore="ContentDescription"/>

        <TextView
            android:id="@+id/right_degree"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_gravity="center"
            android:paddingStart="4dp"
            android:paddingVertical="2dp"
            android:minWidth="40dp"
            android:textColor="@color/text_color_secondary_selector"
            android:background="@color/WHITESMOKE"
            android:text="@string/degree_placeholder" />
    </LinearLayout>

    <LinearLayout
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="10">

        <ImageView
            android:src="@drawable/arrows"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            app:tint="@color/image_tint_selector"
            tools:ignore="ContentDescription"/>

        <it.lmqv.livematchcam.views.ToggleTextView
            android:id="@+id/angle_degree_x"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_gravity="center"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:paddingVertical="2dp"
            android:minWidth="40dp"
            android:textColor="@color/text_color_selector"
            android:hint="@string/degree_placeholder"
            android:text="@string/degree_placeholder" />

        <ImageView
            android:src="@drawable/arrows"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="match_parent"
            android:rotation="90"
            android:layout_gravity="center"
            app:tint="@color/image_tint_selector"
            tools:ignore="ContentDescription"/>

        <it.lmqv.livematchcam.views.ToggleTextView
            android:id="@+id/angle_degree_z"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_gravity="center"
            android:paddingStart="4dp"
            android:paddingEnd="0dp"
            android:paddingVertical="2dp"
            android:minWidth="40dp"
            android:textColor="@color/text_color_selector"
            android:hint="@string/degree_placeholder"
            android:text="@string/degree_placeholder" />

    </LinearLayout>

    <!--LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:weightSum="2">

        <TextView
            android:id="@+id/sourceResolution"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/primary"
            android:background="@drawable/alpha_background"
            android:padding="3dp"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:text="@string/resolution_placeholder" />

        <TextView
            android:id="@+id/sourceFps"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/primary"
            android:background="@drawable/alpha_background"
            android:padding="3dp"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:text="@string/fps_placeholder" />
    </LinearLayout-->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="5">

        <ImageView
            android:visibility="gone"
            android:src="@drawable/target_zoom"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            app:tint="@color/image_tint_selector"
            tools:ignore="ContentDescription"/>

        <it.lmqv.livematchcam.views.ToggleTextView
            android:visibility="gone"
            android:id="@+id/zoom_level"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_gravity="center"
            android:padding="3dp"
            android:minWidth="30dp"
            android:textColor="@color/primary"
            android:text="@string/zoom_placeholder" />

        <ImageView
            android:src="@drawable/magnifer_zoom"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            app:tint="@color/image_tint_selector"
            tools:ignore="ContentDescription"/>

        <TextView
            android:id="@+id/initial_zoom"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_gravity="center"
            android:padding="3dp"
            android:minWidth="30dp"
            android:textColor="@color/primary"
            android:text="@string/zoom_placeholder" />

    </LinearLayout>

    <LinearLayout
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/reset_rotation"
            android:src="@drawable/switch_icon"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            app:tint="@color/image_tint_selector"
            tools:ignore="ContentDescription"/>

        <ImageView
            android:id="@+id/zoom_offset"
            android:src="@drawable/zoom_offset"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:padding="8dp"
            android:layout_gravity="center"
            app:tint="@color/image_tint_selector"
            tools:ignore="ContentDescription"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/zoom_out"
            android:src="@drawable/minus"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:padding="6dp"
            app:tint="@color/image_tint_selector"
            tools:ignore="ContentDescription"/>

        <ImageView
            android:id="@+id/zoom_in"
            android:src="@drawable/add"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:padding="6dp"
            android:layout_gravity="center"
            app:tint="@color/image_tint_selector"
            tools:ignore="ContentDescription"/>
    </LinearLayout>
</LinearLayout>