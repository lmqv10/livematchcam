<?xml version="1.0" encoding="utf-8"?>
<!--
    btn_youtube_connect.xml
    Bottone "Connetti con YouTube" conforme alle linee guida Google Branding.
    Struttura: [Logo G | Testo + Logo YouTube]
    Usage: include questo layout oppure copia il LinearLayout nel tuo layout.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/btnYouTubeConnect"
    android:layout_width="wrap_content"
    android:layout_height="46dp"
    android:orientation="horizontal"
    android:background="@drawable/bg_youtube_button"
    android:clickable="true"
    android:focusable="true"
    android:elevation="2dp"
    android:stateListAnimator="@null">

    <!-- Sezione sinistra: Logo Google G (sfondo bianco, OBBLIGATORIO) -->
    <FrameLayout
        android:layout_width="46dp"
        android:layout_height="match_parent"
        android:background="@drawable/bg_youtube_button_google">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_google_logo"
            android:contentDescription="@string/google_logo_desc"/>

    </FrameLayout>

    <!-- Divisore verticale -->
    <View
        android:layout_width="0.5dp"
        android:layout_height="match_parent"
        android:background="@color/yt_button_divider"/>

    <!-- Sezione destra: Label + Logo YouTube (sfondo rosso) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="20dp"
        android:background="@drawable/bg_youtube_button_label">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_youtube_logo"
            android:contentDescription="@null"/>

        <TextView
            android:id="@+id/tvYouTubeButtonLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/yt_button_label"
            android:textColor="@color/yt_button_text"
            android:textSize="14sp"
            android:textStyle="normal"
            android:letterSpacing="0.01"
            android:fontFamily="sans-serif-medium"
            android:singleLine="true"/>

    </LinearLayout>

</LinearLayout>
