<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/volley_score_board_width"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="@dimen/volley_score_board_width"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/TRANSPARENT"
        android:padding="2dp">
    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/score_board_lightgray_background"
        android:padding="2dp"
        android:layout_marginVertical="7dp"
        android:layout_marginStart="7dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/home_color_bar"
                android:layout_width="5dp"
                android:layout_height="24dp"
                android:orientation="vertical"
                android:background="@color/TRANSPARENT"
                android:layout_marginEnd="2dp"/>

            <GridLayout
                android:layout_width="@dimen/volley_score_board_team"
                android:layout_height="wrap_content"
                android:columnCount="3">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:id="@+id/home_shirt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/shirt_layers" />

                    <ImageView
                        android:id="@+id/home_logo"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/shield" />
                </FrameLayout>

                <TextView
                    android:id="@+id/home_team"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="2"
                    android:textColor="@color/BLACK"
                    android:text="@string/hint_home_team"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <!--ImageView
                    android:id="@+id/home_serve"
                    android:layout_width="0dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical"
                    android:layout_columnWeight="1"
                    android:src="@drawable/sport_volley" /-->

                <!--TextView
                    android:id="@+id/home_score_sets"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_gravity="center_vertical"
                    android:gravity="center_horizontal"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary_dark"
                    android:text="@string/score_placeholder" /-->
            </GridLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/home_score_1set"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:visibility="gone"
                    android:id="@+id/home_score_2set"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:visibility="gone"
                    android:id="@+id/home_score_3set"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:visibility="gone"
                    android:id="@+id/home_score_4set"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:visibility="gone"
                    android:id="@+id/home_score_5set"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:text="@string/score_placeholder" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/away_color_bar"
                android:layout_width="5dp"
                android:layout_height="24dp"
                android:orientation="vertical"
                android:background="@color/TRANSPARENT"
                android:layout_marginEnd="2dp"/>

            <GridLayout
                android:layout_width="@dimen/volley_score_board_team"
                android:layout_height="wrap_content"
                android:columnCount="3">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:id="@+id/away_shirt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/shirt_layers" />

                    <ImageView
                        android:id="@+id/away_logo"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/shield" />
                </FrameLayout>

                <TextView
                    android:id="@+id/away_team"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="2"
                    android:textColor="@color/BLACK"
                    android:text="@string/hint_away_team"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <!--ImageView
                    android:id="@+id/away_serve"
                    android:layout_width="0dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical"
                    android:layout_columnWeight="1"
                    android:src="@drawable/sport_volley" /-->

                <!--TextView
                    android:id="@+id/away_score_sets"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_gravity="center_vertical"
                    android:gravity="center_horizontal"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary_dark"
                    android:text="@string/score_placeholder" /-->

            </GridLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/away_score_1set"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:visibility="gone"
                    android:id="@+id/away_score_2set"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:visibility="gone"
                    android:id="@+id/away_score_3set"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:visibility="gone"
                    android:id="@+id/away_score_4set"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:visibility="gone"
                    android:id="@+id/away_score_5set"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:text="@string/score_placeholder" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/match_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/BLACK"
            android:text=""
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center" />

    </LinearLayout>

</FrameLayout>