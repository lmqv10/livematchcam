<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/score_board_primary_background"
        android:padding="2dp"
        android:layout_margin="7dp">


        <TableLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:stretchColumns="*">

            <TableRow
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/home_logo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:src="@drawable/shirt_layers"
                    android:gravity="start" />

                <TextView
                    android:id="@+id/home_team"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:textColor="@color/BLACK"
                    android:text="@string/hint_home_team"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/home_score_1set"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:background="@drawable/score_board_primary_background"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:id="@+id/home_score_2set"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:background="@drawable/score_board_primary_background"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:id="@+id/home_score_3set"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:background="@drawable/score_board_primary_background"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:id="@+id/home_score_4set"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:background="@drawable/score_board_primary_background"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:id="@+id/home_score_5set"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:background="@drawable/score_board_primary_background"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:id="@+id/home_score_sets"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:background="@drawable/score_board_secondary_background"
                    android:text="@string/score_placeholder" />
            </TableRow>

            <TableRow
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/away_logo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:src="@drawable/shirt_layers"
                    android:gravity="start" />

                <TextView
                    android:id="@+id/away_team"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:textColor="@color/BLACK"
                    android:text="@string/hint_away_team"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/away_score_1set"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:background="@drawable/score_board_primary_background"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:id="@+id/away_score_2set"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:background="@drawable/score_board_primary_background"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:id="@+id/away_score_3set"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:background="@drawable/score_board_primary_background"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:id="@+id/away_score_4set"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:background="@drawable/score_board_primary_background"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:id="@+id/away_score_5set"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:background="@drawable/score_board_primary_background"
                    android:text="@string/score_placeholder" />

                <TextView
                    android:id="@+id/away_score_sets"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:background="@drawable/score_board_secondary_background"
                    android:text="@string/score_placeholder" />

            </TableRow>

        </TableLayout>

        <TextView
            android:id="@+id/match_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/BLACK"
            android:text=""
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center" />

