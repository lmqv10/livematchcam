<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dialogRoot"
    android:layout_width="@dimen/dialog_width"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/score_board_primary_background"
    android:padding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/filter_preview_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/alpha_background"
        android:layout_marginBottom="10dp"
        android:clickable="true"
        android:focusable="true"
        android:clipChildren="true"
        android:clipToPadding="true">

        <GridLayout
            android:id="@+id/position_grid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="3"
            android:useDefaultMargins="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/btn_pos_top_left"
                android:layout_width="@dimen/filter_placeholder_width"
                android:layout_height="@dimen/filter_placeholder_height"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@string/description_placeholder"
                android:src="@drawable/ic_spot_top_left"
                android:layout_margin="2dp" />

            <ImageButton
                android:id="@+id/btn_pos_top"
                android:layout_width="@dimen/filter_placeholder_width"
                android:layout_height="@dimen/filter_placeholder_height"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@string/description_placeholder"
                android:src="@drawable/ic_spot_top"
                android:layout_margin="2dp" />

            <ImageButton
                android:id="@+id/btn_pos_top_right"
                android:layout_width="@dimen/filter_placeholder_width"
                android:layout_height="@dimen/filter_placeholder_height"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@string/description_placeholder"
                android:src="@drawable/ic_spot_top_right"
                android:layout_margin="2dp" />

            <Space
                android:layout_width="@dimen/filter_placeholder_width"
                android:layout_height="@dimen/filter_placeholder_height"
                android:layout_margin="2dp" />

            <ImageButton
                android:id="@+id/btn_pos_center"
                android:layout_width="@dimen/filter_placeholder_width"
                android:layout_height="@dimen/filter_placeholder_height"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@string/description_placeholder"
                android:src="@drawable/ic_spot_center"
                android:layout_margin="2dp" />

            <Space
                android:layout_width="@dimen/filter_placeholder_width"
                android:layout_height="@dimen/filter_placeholder_height"
                android:layout_margin="2dp" />

            <ImageButton
                android:id="@+id/btn_pos_bottom_left"
                android:layout_width="@dimen/filter_placeholder_width"
                android:layout_height="@dimen/filter_placeholder_height"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@string/description_placeholder"
                android:src="@drawable/ic_spot_bottom_left"
                android:layout_margin="2dp" />

            <ImageButton
                android:id="@+id/btn_pos_bottom"
                android:layout_width="@dimen/filter_placeholder_width"
                android:layout_height="@dimen/filter_placeholder_height"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@string/description_placeholder"
                android:src="@drawable/ic_spot_bottom"
                android:layout_margin="2dp" />

            <ImageButton
                android:id="@+id/btn_pos_bottom_right"
                android:layout_width="@dimen/filter_placeholder_width"
                android:layout_height="@dimen/filter_placeholder_height"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@string/description_placeholder"
                android:src="@drawable/ic_spot_bottom_right"
                android:layout_margin="2dp" />

        </GridLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/filter_preview_viewport"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipChildren="true"
            android:clipToPadding="true"
            android:alpha="1"
            app:layout_constraintDimensionRatio="16:9"
            app:layout_constraintStart_toStartOf="@+id/position_grid"
            app:layout_constraintEnd_toEndOf="@+id/position_grid"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline_h_center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.5" />

            <ImageView
                android:id="@+id/filter_url_preview"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clickable="false"
                android:src="@drawable/preview_missing"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:ignore="ContentDescription" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

<!--    <View-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="1dp"-->
<!--        android:background="@android:color/darker_gray"-->
<!--        android:layout_marginVertical="5dp"/>-->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/filter_url_edit_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/filter_url_edit"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/preview_missing"
                tools:ignore="ContentDescription" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="25dp"
                android:background="@android:color/darker_gray" />

        </LinearLayout>

        <ImageView
            android:id="@+id/filter_decrease_size"
            android:src="@drawable/minus"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:padding="2dp"
            android:layout_gravity="center"
            tools:ignore="ContentDescription"/>

        <SeekBar
            android:id="@+id/slider_size"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:minHeight="30dp"
            android:max="100"
            android:min="5"
            android:progress="5"
            android:splitTrack="false"
            android:progressBackgroundTint="@color/primary"
            android:progressBackgroundTintMode="screen"
            android:thumb="@drawable/custom_seekbar_thumb" />

        <ImageView
            android:id="@+id/filter_increase_size"
            android:src="@drawable/add"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:padding="2dp"
            android:layout_gravity="center"
            tools:ignore="ContentDescription"/>

        <TextView
            android:id="@+id/text_slider_size"
            android:layout_width="wrap_content"
            android:minWidth="35dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:paddingVertical="4dp"
            android:gravity="center"
            android:background="@drawable/secondary_background"
            android:textSize="@dimen/text_size_normal"
            android:textColor="@color/primary"
            tools:text="@string/description_placeholder" />

        <TextView
            android:visibility="gone"
            android:id="@+id/switch_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/hide_scoreboard"
            android:gravity="center"
            android:textColor="@color/secondary" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@android:color/darker_gray"
            android:layout_marginHorizontal="25dp"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="30dp"
            android:textColor="@color/primary" />
    </LinearLayout>

<!--    <View-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="1dp"-->
<!--        android:background="@android:color/darker_gray"-->
<!--        android:layout_marginVertical="5dp"/>-->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="4dp"
        android:layout_marginTop="10dp">

        <ImageView
            style="@style/DefaultImageViewStyle"
            android:id="@+id/cancelButton"
            android:src="@drawable/ic_cancel"
            android:layout_gravity="start"
            android:contentDescription="@string/description_placeholder"
            android:layout_marginEnd="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/confirmButton"/>

        <ImageView
            style="@style/DefaultImageViewStyle"
            android:id="@+id/confirmButton"
            android:src="@drawable/ic_confirm"
            android:contentDescription="@string/description_placeholder"
            android:layout_marginEnd="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>
